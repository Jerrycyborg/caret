# AI provider secrets are runtime/env only.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
AZURE_API_KEY=
OLLAMA_API_BASE=http://localhost:11434

# Deployment identity.
OXY_ORG_NAME=Oxy Internal
OXY_ENV_LABEL=development

# Support policy.
OXY_SUPPORT_AUTO_FIX_ENABLED=true
OXY_SUPPORT_ESCALATION_POLICY=manual_review
OXY_SUPPORT_DAEMON_INTERVAL=300
OXY_SUPPORT_DAEMON_COOLDOWN_MINUTES=360

# Ticketing.
OXY_TICKETING_ADAPTER=jira
OXY_JIRA_BASE_URL=
OXY_JIRA_PROJECT_KEY=
OXY_JIRA_ISSUE_TYPE=Task
OXY_JIRA_USER_EMAIL=
OXY_JIRA_API_TOKEN=
OXY_JIRA_LABELS=
OXY_JIRA_COMPONENTS=

# Integrations.
OXY_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
OXY_WHATSAPP_ENABLED=false
OXY_OPENCLAW_ENABLED=true
OXY_WRAITH_ENABLED=true
